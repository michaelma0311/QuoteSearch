# Required for Pinecone semantic search
PINECONE_API_KEY=your_pinecone_key
PINECONE_INDEX=to2csearch-tale
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=tale-of-two-cities

# Required only if you use --embedding-provider openai
OPENAI_API_KEY=your_openai_key
OPENAI_EMBED_MODEL=text-embedding-3-small

